# ──────────────────────────────────────────────────────────────
# KassyThreads environment — copy to .env and fill in real values.
# ──────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_USER=kassythreads
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=kassythreads
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Single connection string used by the API (Mikro-ORM).
DATABASE_URL=postgres://kassythreads:change-me-postgres@localhost:5432/kassythreads

# ── MinIO (object storage: videos, images, before/after) ────────
MINIO_ROOT_USER=kassythreads
MINIO_ROOT_PASSWORD=change-me-minio
# Public base URL the browser uses to load media (videos/hero.mp4, etc.)
NEXT_PUBLIC_MINIO_URL=http://localhost:9000/kassythreads

# ── imgproxy (on-the-fly image optimization) ────────────────────
# Generate with: openssl rand -hex 32
IMGPROXY_KEY=change-me-imgproxy-key
IMGPROXY_SALT=change-me-imgproxy-salt
# Public base URL the custom next/image loader points at.
NEXT_PUBLIC_IMGPROXY_URL=http://localhost:8080

# ── API <-> Web wiring ──────────────────────────────────────────
# Server-to-server (RSC fetch, build time).
API_URL=http://localhost:4000
# Browser-facing API base.
NEXT_PUBLIC_API_URL=http://localhost:4000
# Allowed CORS origin for the API.
WEB_ORIGIN=http://localhost:3000

# ── Resend (transactional email) ────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── Stripe (deposits & payments) ────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# ── Instagram Basic Display API (UGC social wall) ───────────────
INSTAGRAM_ACCESS_TOKEN=ig-long-lived-token
INSTAGRAM_USER_ID=your-instagram-user-id
# App secret — only needed to exchange a short-lived token for a long-lived one.
INSTAGRAM_APP_SECRET=your-instagram-app-secret

# ── ntfy (push notifications) ───────────────────────────────────
NTFY_BASE_URL=http://localhost:8090
NTFY_TOPIC=kassythreads-bookings

# ── Cloudflare Tunnel (production ingress) ──────────────────────
# Production is exposed via cloudflared — no inbound ports, no Caddy SSL.
# Create a tunnel in the Cloudflare Zero Trust dashboard, point its public
# hostname at http://caddy:80, then paste the tunnel token here.
TUNNEL_TOKEN=

# Public site domain (informational / used in prod env wiring below).
DOMAIN=kassythreads.com

# ── Production overrides ────────────────────────────────────────
# In production the browser-facing URLs are same-origin paths behind the tunnel.
# Copy these into .env on the VPS (replacing the localhost values above):
#   NODE_ENV=production
#   API_URL=http://caddy:80
#   NEXT_PUBLIC_API_URL=https://kassythreads.com
#   NEXT_PUBLIC_MINIO_URL=https://kassythreads.com/img/... (or a media subdomain)
#   NEXT_PUBLIC_IMGPROXY_URL=https://kassythreads.com/img
#   WEB_ORIGIN=https://kassythreads.com
